{
  "name": "rojo-explorer",
  "displayName": "%rojoExplorer.displayName%",
  "description": "%rojoExplorer.description%",
  "version": "0.0.1",
  "publisher": "local-dev",
  "private": true,
  "license": "MIT",
  "keywords": [
    "roblox",
    "rojo",
    "vscode-extension",
    "explorer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Demon673/rojo-explorer.git"
  },
  "bugs": {
    "url": "https://github.com/Demon673/rojo-explorer/issues"
  },
  "homepage": "https://github.com/Demon673/rojo-explorer#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "l10n": "./l10n",
  "activationEvents": [
    "onView:rojoExplorer.views.explorer",
    "onCommand:rojoExplorer.refresh",
    "onCommand:rojoExplorer.openRojoProject",
    "onCommand:rojoExplorer.selectNode",
    "onCommand:rojoExplorer.revealInVsCodeExplorer",
    "onCommand:rojoExplorer.copyStudioPath",
    "onCommand:rojoExplorer.copySourcePath",
    "onCommand:rojoExplorer.copyRelativeSourcePath",
    "onCommand:rojoExplorer.createFolder",
    "onCommand:rojoExplorer.createScript",
    "onCommand:rojoExplorer.createLocalScript",
    "onCommand:rojoExplorer.createModuleScript",
    "onCommand:rojoExplorer.createInitScript",
    "onCommand:rojoExplorer.removeInitScript",
    "onCommand:rojoExplorer.createInstance",
    "onCommand:rojoExplorer.createModel",
    "onCommand:rojoExplorer.createRemoteEvent",
    "onCommand:rojoExplorer.createRemoteFunction",
    "onCommand:rojoExplorer.createBindableEvent",
    "onCommand:rojoExplorer.createBindableFunction",
    "onCommand:rojoExplorer.createStringValue",
    "onCommand:rojoExplorer.createBoolValue",
    "onCommand:rojoExplorer.createIntValue",
    "onCommand:rojoExplorer.createNumberValue",
    "onCommand:rojoExplorer.createObjectValue",
    "onCommand:rojoExplorer.createVector3Value",
    "onCommand:rojoExplorer.createCFrameValue",
    "onCommand:rojoExplorer.createColor3Value",
    "onCommand:rojoExplorer.createBrickColorValue",
    "onCommand:rojoExplorer.createLocalizationTable",
    "onCommand:rojoExplorer.createJsonModule",
    "onCommand:rojoExplorer.createTomlModule",
    "onCommand:rojoExplorer.renameResource",
    "onCommand:rojoExplorer.duplicateResource",
    "onCommand:rojoExplorer.openResourceMeta",
    "onCommand:rojoExplorer.openResourceInitMeta",
    "onCommand:rojoExplorer.moveResource",
    "onCommand:rojoExplorer.deleteResource",
    "onCommand:rojoExplorer.editProjectMapping",
    "workspaceContains:**/*.project.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rojoExplorer.refresh",
        "title": "%rojoExplorer.commands.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "rojoExplorer.openRojoProject",
        "title": "%rojoExplorer.commands.openRojoProject.title%",
        "icon": "$(json)"
      },
      {
        "command": "rojoExplorer.openResource",
        "title": "%rojoExplorer.commands.openResource.title%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "rojoExplorer.selectNode",
        "title": "%rojoExplorer.commands.selectNode.title%"
      },
      {
        "command": "rojoExplorer.revealInFileExplorer",
        "title": "%rojoExplorer.commands.revealInFileExplorer.title%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "rojoExplorer.revealInVsCodeExplorer",
        "title": "%rojoExplorer.commands.revealInVsCodeExplorer.title%",
        "icon": "$(list-tree)"
      },
      {
        "command": "rojoExplorer.copyStudioPath",
        "title": "%rojoExplorer.commands.copyStudioPath.title%",
        "icon": "$(copy)"
      },
      {
        "command": "rojoExplorer.copySourcePath",
        "title": "%rojoExplorer.commands.copySourcePath.title%",
        "icon": "$(clippy)"
      },
      {
        "command": "rojoExplorer.copyRelativeSourcePath",
        "title": "%rojoExplorer.commands.copyRelativeSourcePath.title%",
        "icon": "$(copy)"
      },
      {
        "command": "rojoExplorer.createFolder",
        "title": "%rojoExplorer.commands.createFolder.title%",
        "icon": "$(new-folder)"
      },
      {
        "command": "rojoExplorer.createScript",
        "title": "%rojoExplorer.commands.createScript.title%",
        "icon": "$(file-code)"
      },
      {
        "command": "rojoExplorer.createLocalScript",
        "title": "%rojoExplorer.commands.createLocalScript.title%",
        "icon": "$(device-mobile)"
      },
      {
        "command": "rojoExplorer.createModuleScript",
        "title": "%rojoExplorer.commands.createModuleScript.title%",
        "icon": "$(symbol-module)"
      },
      {
        "command": "rojoExplorer.createInitScript",
        "title": "%rojoExplorer.commands.createInitScript.title%",
        "icon": "$(file-code)"
      },
      {
        "command": "rojoExplorer.removeInitScript",
        "title": "%rojoExplorer.commands.removeInitScript.title%",
        "icon": "$(close)"
      },
      {
        "command": "rojoExplorer.createInstance",
        "title": "%rojoExplorer.commands.createInstance.title%",
        "icon": "$(add)"
      },
      {
        "command": "rojoExplorer.createModel",
        "title": "%rojoExplorer.commands.createModel.title%",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "rojoExplorer.createRemoteEvent",
        "title": "%rojoExplorer.commands.createRemoteEvent.title%",
        "icon": "$(symbol-event)"
      },
      {
        "command": "rojoExplorer.createRemoteFunction",
        "title": "%rojoExplorer.commands.createRemoteFunction.title%",
        "icon": "$(symbol-method)"
      },
      {
        "command": "rojoExplorer.createBindableEvent",
        "title": "%rojoExplorer.commands.createBindableEvent.title%",
        "icon": "$(symbol-event)"
      },
      {
        "command": "rojoExplorer.createBindableFunction",
        "title": "%rojoExplorer.commands.createBindableFunction.title%",
        "icon": "$(symbol-method)"
      },
      {
        "command": "rojoExplorer.createStringValue",
        "title": "%rojoExplorer.commands.createStringValue.title%",
        "icon": "$(symbol-string)"
      },
      {
        "command": "rojoExplorer.createBoolValue",
        "title": "%rojoExplorer.commands.createBoolValue.title%",
        "icon": "$(symbol-boolean)"
      },
      {
        "command": "rojoExplorer.createIntValue",
        "title": "%rojoExplorer.commands.createIntValue.title%",
        "icon": "$(symbol-number)"
      },
      {
        "command": "rojoExplorer.createNumberValue",
        "title": "%rojoExplorer.commands.createNumberValue.title%",
        "icon": "$(symbol-number)"
      },
      {
        "command": "rojoExplorer.createObjectValue",
        "title": "%rojoExplorer.commands.createObjectValue.title%",
        "icon": "$(symbol-reference)"
      },
      {
        "command": "rojoExplorer.createVector3Value",
        "title": "%rojoExplorer.commands.createVector3Value.title%",
        "icon": "$(symbol-operator)"
      },
      {
        "command": "rojoExplorer.createCFrameValue",
        "title": "%rojoExplorer.commands.createCFrameValue.title%",
        "icon": "$(symbol-operator)"
      },
      {
        "command": "rojoExplorer.createColor3Value",
        "title": "%rojoExplorer.commands.createColor3Value.title%",
        "icon": "$(symbol-color)"
      },
      {
        "command": "rojoExplorer.createBrickColorValue",
        "title": "%rojoExplorer.commands.createBrickColorValue.title%",
        "icon": "$(symbol-color)"
      },
      {
        "command": "rojoExplorer.createLocalizationTable",
        "title": "%rojoExplorer.commands.createLocalizationTable.title%",
        "icon": "$(table)"
      },
      {
        "command": "rojoExplorer.createJsonModule",
        "title": "%rojoExplorer.commands.createJsonModule.title%",
        "icon": "$(json)"
      },
      {
        "command": "rojoExplorer.createTomlModule",
        "title": "%rojoExplorer.commands.createTomlModule.title%",
        "icon": "$(symbol-property)"
      },
      {
        "command": "rojoExplorer.renameResource",
        "title": "%rojoExplorer.commands.renameResource.title%",
        "icon": "$(edit)"
      },
      {
        "command": "rojoExplorer.duplicateResource",
        "title": "%rojoExplorer.commands.duplicateResource.title%",
        "icon": "$(copy)"
      },
      {
        "command": "rojoExplorer.openResourceMeta",
        "title": "%rojoExplorer.commands.openResourceMeta.title%",
        "icon": "$(json)"
      },
      {
        "command": "rojoExplorer.openResourceInitMeta",
        "title": "%rojoExplorer.commands.openResourceInitMeta.title%",
        "icon": "$(json)"
      },
      {
        "command": "rojoExplorer.moveResource",
        "title": "%rojoExplorer.commands.moveResource.title%",
        "icon": "$(arrow-right)"
      },
      {
        "command": "rojoExplorer.deleteResource",
        "title": "%rojoExplorer.commands.deleteResource.title%",
        "icon": "$(trash)"
      },
      {
        "command": "rojoExplorer.editProjectMapping",
        "title": "%rojoExplorer.commands.editProjectMapping.title%",
        "icon": "$(json)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rojoExplorer.refresh",
          "when": "view == rojoExplorer.views.explorer",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.openRojoProject",
          "when": "view == rojoExplorer.views.explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "rojoExplorer.openResource",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /resource/",
          "group": "inline"
        },
        {
          "command": "rojoExplorer.revealInFileExplorer",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /resource/",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.revealInVsCodeExplorer",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /resource/",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.copyStudioPath",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /studioPath/",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.copySourcePath",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /resource/",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.copyRelativeSourcePath",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /resource/",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.renameResource",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /renameable/",
          "group": "resource-edit@1"
        },
        {
          "command": "rojoExplorer.duplicateResource",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /duplicateable/",
          "group": "resource-edit@2"
        },
        {
          "command": "rojoExplorer.moveResource",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /movable/",
          "group": "resource-edit@3"
        },
        {
          "command": "rojoExplorer.openResourceMeta",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /metaEditable/",
          "group": "resource-edit@4"
        },
        {
          "command": "rojoExplorer.openResourceInitMeta",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /initMetaEditable/",
          "group": "resource-edit@5"
        },
        {
          "command": "rojoExplorer.removeInitScript",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /initScriptRemovable/",
          "group": "resource-edit@6"
        },
        {
          "command": "rojoExplorer.editProjectMapping",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /projectControlled/",
          "group": "resource-edit@7"
        },
        {
          "command": "rojoExplorer.deleteResource",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /deletable/",
          "group": "resource-edit@8"
        },
        {
          "command": "rojoExplorer.createFolder",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@1"
        },
        {
          "command": "rojoExplorer.createScript",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@2"
        },
        {
          "command": "rojoExplorer.createLocalScript",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@3"
        },
        {
          "command": "rojoExplorer.createModuleScript",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@4"
        },
        {
          "command": "rojoExplorer.createInitScript",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /initScriptCreatable/",
          "group": "resource-create@5"
        },
        {
          "command": "rojoExplorer.createInstance",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@6"
        },
        {
          "command": "rojoExplorer.createModel",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@7"
        },
        {
          "command": "rojoExplorer.createRemoteEvent",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@8"
        },
        {
          "command": "rojoExplorer.createRemoteFunction",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@9"
        },
        {
          "command": "rojoExplorer.createBindableEvent",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@10"
        },
        {
          "command": "rojoExplorer.createBindableFunction",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@11"
        },
        {
          "command": "rojoExplorer.createStringValue",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@12"
        },
        {
          "command": "rojoExplorer.createBoolValue",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@13"
        },
        {
          "command": "rojoExplorer.createIntValue",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@14"
        },
        {
          "command": "rojoExplorer.createNumberValue",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@15"
        },
        {
          "command": "rojoExplorer.createObjectValue",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@16"
        },
        {
          "command": "rojoExplorer.createVector3Value",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@17"
        },
        {
          "command": "rojoExplorer.createCFrameValue",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@18"
        },
        {
          "command": "rojoExplorer.createColor3Value",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@19"
        },
        {
          "command": "rojoExplorer.createBrickColorValue",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@20"
        },
        {
          "command": "rojoExplorer.createLocalizationTable",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@21"
        },
        {
          "command": "rojoExplorer.createJsonModule",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@22"
        },
        {
          "command": "rojoExplorer.createTomlModule",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /createChildren/",
          "group": "resource-create@23"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "rojoExplorer.views.explorer",
          "name": "%rojoExplorer.views.explorer.name%",
          "when": "workspaceFolderCount != 0"
        }
      ]
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "npm run clean && tsc -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "vitest": "^4.1.8",
    "typescript": "^5.5.4"
  }
}
