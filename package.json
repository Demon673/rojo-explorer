{
  "name": "rojo-explorer",
  "displayName": "%rojoExplorer.displayName%",
  "description": "%rojoExplorer.description%",
  "version": "0.0.1",
  "publisher": "local-dev",
  "private": true,
  "license": "MIT",
  "keywords": [
    "roblox",
    "rojo",
    "vscode-extension",
    "explorer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Demon673/rojo-explorer.git"
  },
  "bugs": {
    "url": "https://github.com/Demon673/rojo-explorer/issues"
  },
  "homepage": "https://github.com/Demon673/rojo-explorer#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "l10n": "./l10n",
  "activationEvents": [
    "onView:rojoExplorer.views.explorer",
    "onCommand:rojoExplorer.refresh",
    "onCommand:rojoExplorer.openRojoProject",
    "onCommand:rojoExplorer.revealInVsCodeExplorer",
    "onCommand:rojoExplorer.copyStudioPath",
    "onCommand:rojoExplorer.copySourcePath",
    "workspaceContains:**/*.project.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rojoExplorer.refresh",
        "title": "%rojoExplorer.commands.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "rojoExplorer.openRojoProject",
        "title": "%rojoExplorer.commands.openRojoProject.title%",
        "icon": "$(json)"
      },
      {
        "command": "rojoExplorer.openResource",
        "title": "%rojoExplorer.commands.openResource.title%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "rojoExplorer.revealInFileExplorer",
        "title": "%rojoExplorer.commands.revealInFileExplorer.title%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "rojoExplorer.revealInVsCodeExplorer",
        "title": "%rojoExplorer.commands.revealInVsCodeExplorer.title%",
        "icon": "$(list-tree)"
      },
      {
        "command": "rojoExplorer.copyStudioPath",
        "title": "%rojoExplorer.commands.copyStudioPath.title%",
        "icon": "$(copy)"
      },
      {
        "command": "rojoExplorer.copySourcePath",
        "title": "%rojoExplorer.commands.copySourcePath.title%",
        "icon": "$(clippy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rojoExplorer.refresh",
          "when": "view == rojoExplorer.views.explorer",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.openRojoProject",
          "when": "view == rojoExplorer.views.explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "rojoExplorer.openResource",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /resource/",
          "group": "inline"
        },
        {
          "command": "rojoExplorer.revealInFileExplorer",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /resource/",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.revealInVsCodeExplorer",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /resource/",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.copyStudioPath",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /studioPath/",
          "group": "navigation"
        },
        {
          "command": "rojoExplorer.copySourcePath",
          "when": "view == rojoExplorer.views.explorer && viewItem =~ /resource/",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "rojoExplorer.views.explorer",
          "name": "%rojoExplorer.views.explorer.name%",
          "when": "workspaceFolderCount != 0"
        }
      ]
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "npm run clean && tsc -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "vitest": "^4.1.8",
    "typescript": "^5.5.4"
  }
}
